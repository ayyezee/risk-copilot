# Application
APP_NAME=Document Processor
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# API
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docprocessor

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 2FA
TOTP_ISSUER=DocumentProcessor

# AI Services (at least one required for full functionality)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEFAULT_AI_PROVIDER=openai

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads

# S3 Storage (if STORAGE_BACKEND=s3)
# S3_BUCKET_NAME=your-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Vector Store
CHROMA_PERSIST_DIRECTORY=./chroma_data
EMBEDDING_MODEL=text-embedding-3-small

# File Processing
MAX_FILE_SIZE_MB=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring (optional)
# SENTRY_DSN=https://your-sentry-dsn
LOG_LEVEL=INFO
